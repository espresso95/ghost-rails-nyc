# Backend
GHOST_RAILS_API_HOST=127.0.0.1
GHOST_RAILS_API_PORT=8000
GHOST_RAILS_ENV=development

# Model profile
GHOST_RAILS_MODEL_PROFILE=local_m2_16gb

# Chat model role
GHOST_RAILS_CHAT_PROVIDER=ollama
GHOST_RAILS_CHAT_MODEL=llama3.2:3b
GHOST_RAILS_CHAT_BASE_URL=http://localhost:11434
GHOST_RAILS_CHAT_TIMEOUT_SECONDS=120
GHOST_RAILS_CHAT_TEMPERATURE=0.1
GHOST_RAILS_CHAT_MAX_OUTPUT_TOKENS=512
GHOST_RAILS_ENABLE_LLM_ANSWERS=false

# Embedding model role
GHOST_RAILS_EMBEDDING_PROVIDER=ollama
GHOST_RAILS_EMBEDDING_MODEL=nomic-embed-text
GHOST_RAILS_EMBEDDING_BASE_URL=http://localhost:11434
GHOST_RAILS_EMBEDDING_TIMEOUT_SECONDS=120

# Retrieval defaults tuned for 16GB Apple Silicon development
GHOST_RAILS_RETRIEVAL_PROVIDER=local_lexical
GHOST_RAILS_SIMILARITY_TOP_K=6
GHOST_RAILS_CONTEXT_CHUNKS=3
GHOST_RAILS_MAX_CONTEXT_TOKENS=3500

# Shared Ollama base URL fallback
OLLAMA_BASE_URL=http://localhost:11434

# Optional cloud chat providers
# GHOST_RAILS_CHAT_PROVIDER=groq
# GHOST_RAILS_CHAT_MODEL=llama-3.1-8b-instant
# GROQ_API_KEY=

# GHOST_RAILS_CHAT_PROVIDER=gemini
# GHOST_RAILS_CHAT_MODEL=gemini-2.5-flash-lite
# GEMINI_API_KEY=

# Local data paths
GHOST_RAILS_FEATURES_PATH=data/features/features.geojson
GHOST_RAILS_STATIONS_PATH=data/processed/current_stations.json
GHOST_RAILS_SOURCES_PATH=data/sources
GHOST_RAILS_CHROMA_PATH=data/chroma
